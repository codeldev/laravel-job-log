{
    "name": "codeldev/laravel-job-log",
    "version": "1.0.0",
    "description": "A simple Laravel package that automatically logs all jobs queued and processed by your application to the database.",
    "keywords": [
        "CodelDev",
        "laravel",
        "laravel-job-log"
    ],
    "homepage": "https://github.com/codeldev/laravel-job-log",
    "license": "MIT",
    "authors": [
        {
            "name": "CodelDev",
            "email": "support@codel.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.93",
        "illuminate/contracts": "*"
    },
    "require-dev": {
        "larastan/larastan": "^3.9.5",
        "laravel/pint": "^1.29",
        "nunomaduro/collision": "^8.9.3",
        "nunomaduro/pao": "1.0.4",
        "orchestra/testbench": "^11.1.0",
        "peckphp/peck": "^0.3.0",
        "pestphp/pest": "^4.5.0",
        "pestphp/pest-plugin-arch": "^4.0.2",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "rector/rector": "^2.4.1",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "CodelDev\\LaravelJobLog\\": "src/",
            "CodelDev\\LaravelJobLog\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodelDev\\LaravelJobLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test:unit": "pest --parallel --coverage --exactly=100",
        "test:types": "phpstan",
        "test:lint": "pint --test",
        "test:typos": "peck",
        "test:refactor": "rector --dry-run",
        "test": [
            "@test:unit",
            "@test:lint",
            "@test:types",
            "@test:refactor",
            "@test:typos"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodelDev\\LaravelJobLog\\LaravelJobLogServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
